# MongoDB connection string.
# Local dev (default if unset): mongodb://127.0.0.1:27017/vendor_management
# Production (MongoDB Atlas free M0):
#   mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/vendor_management
DATABASE_URL=

# JWT signing secret (use a long random value in production)
JWT_SECRET=vendor-management-dev-secret-change-me

# Seeded admin account (created on first boot if absent)
ADMIN_EMAIL=admin@vendor.com
ADMIN_PASSWORD=admin123

# Email (Gmail SMTP). Leave blank to disable email; the app still runs.
# Create an App Password: Google Account > Security > 2-Step Verification > App passwords.
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=abcdefghijklmnop

# AI assistant (Groq, free tier). Leave blank to disable; chat falls back to canned tips.
# Get a key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
